{
	"schemaVersion": 1,
	"id": "golden-frontier",
	"version": "${version}",
	"name": "Golden Frontier",
	"description": "Wild West mod based on the American Gold Rush, made for the 2026 CurseForge Modjam",
	"authors": [
		"locallupo, BenMcAvoy"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/locallupo/Golden-Frontier"
	},
	"license": "MIT",
	"icon": "assets/golden-frontier/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.locallupo.goldenfrontier.GoldenFrontier"
		],
		"client": [
			"net.locallupo.goldenfrontier.client.GoldenFrontierClient"
		]
	},
	"mixins": [
		"golden-frontier.mixins.json",
		{
			"config": "golden-frontier.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}